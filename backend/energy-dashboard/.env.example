SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=sender@company.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=sender@company.com

# ============================================
# SharePoint Integration (Optional)
# ============================================
# IMPORTANT: These credentials are required to enable SharePoint integration
# They are obtained from Azure AD app registration

# Azure AD Tenant ID
# Get from: Azure Portal > Azure Active Directory > Properties > Tenant ID
SHAREPOINT_TENANT_ID=

# Application (Client) ID
# Get from: Azure Portal > App registrations > Your App > Application ID
SHAREPOINT_CLIENT_ID=

# Client Secret (for Service Principal authentication)
# Get from: Azure Portal > App registrations > Your App > Certificates & secrets
# WARNING: Keep this secret safe and never commit to version control
SHAREPOINT_CLIENT_SECRET=

# Application ID URI (optional, defaults to https://graph.microsoft.com/.default)
SHAREPOINT_APP_ID_URI=https://graph.microsoft.com/.default

