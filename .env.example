# ============================================================================
# ENERGY DASHBOARD - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_ENV=development
APP_NAME=Energy Dashboard
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# ============================================================================
# FASTAPI SERVER
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
FRONTEND_URL=http://localhost:5173

# ============================================================================
# DATABASE (if using)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/energy_db
# SQLALCHEMY_ECHO=False

# ============================================================================
# SHAREPOINT INTEGRATION
# ============================================================================
SHAREPOINT_TENANT_ID=your_tenant_id_here
SHAREPOINT_CLIENT_ID=your_client_id_here
SHAREPOINT_CLIENT_SECRET=your_client_secret_here
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/YourSite
SHAREPOINT_LIST_ID=your_list_id_here

# ============================================================================
# GOOGLE SHEETS INTEGRATION
# ============================================================================
GOOGLE_APPLICATION_CREDENTIALS=./backend/energy-dashboard/google_credentials.json
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SHEET_RANGE=Sheet1!A1:Z1000

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@yourcompany.com
SMTP_USE_TLS=True

# ============================================================================
# SCHEDULING
# ============================================================================
SCHEDULE_INGESTION_DAILY=09:00
SCHEDULE_EMAIL_DAILY=18:00
TIMEZONE=Asia/Kolkata

# ============================================================================
# DATA INGESTION
# ============================================================================
DATA_INGESTION_TIMEOUT=3600
DATA_CACHE_EXPIRY=3600
DATA_RETENTION_DAYS=90

# ============================================================================
# API KEYS
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# CORS SETTINGS (Production only)
# ============================================================================
# ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=
LOG_FILE_PATH=./backend/logs/app.log
