<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Azure App Service configuration for React frontend -->
  <system.webServer>
    <!-- Rewrite rules to support React Router (SPA) -->
    <rewrite>
      <rules>
        <!-- Rule to rewrite all non-file/non-folder requests to index.html -->
        <rule name="React Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchList">
            <!-- If the request is for a file, don't rewrite -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- If the request is for a folder, don't rewrite -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <!-- Rewrite to index.html for SPA routing -->
          <action type="Rewrite" url="/" />
        </rule>
      </rules>
    </rewrite>

    <!-- MIME types for modern web assets -->
    <staticContent>
      <!-- JSON files -->
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <!-- WebAssembly -->
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <!-- Web fonts -->
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".ttf" mimeType="font/ttf" />
      <mimeMap fileExtension=".otf" mimeType="font/otf" />
      <mimeMap fileExtension=".eot" mimeType="application/vnd.ms-fontobject" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>

    <!-- Gzip compression for better performance -->
    <httpCompression>
      <dynamicTypes>
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/x-javascript" enabled="true" />
        <add mimeType="text/css" enabled="true" />
        <add mimeType="text/html" enabled="true" />
        <add mimeType="text/plain" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="text/xml" enabled="true" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/x-javascript" enabled="true" />
        <add mimeType="text/css" enabled="true" />
        <add mimeType="text/html" enabled="true" />
        <add mimeType="text/plain" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="text/xml" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
      </staticTypes>
    </httpCompression>

    <!-- Cache control for static assets -->
    <caching>
      <!-- Cache JavaScript and CSS for 1 day -->
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAgeInSeconds="86400" />
      </staticContent>
    </caching>

    <!-- HTTP response headers -->
    <httpProtocol>
      <customHeaders>
        <!-- Security headers -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <!-- CORS header (if needed, configure properly) -->
        <add name="Access-Control-Allow-Origin" value="*" />
      </customHeaders>
    </httpProtocol>

    <!-- Prevent directory listing -->
    <directoryBrowse enabled="false" />

    <!-- Request filtering -->
    <security>
      <requestFiltering>
        <!-- Deny access to sensitive files -->
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".config" allowed="false" />
          <add fileExtension=".git" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
  </system.webServer>

  <!-- App settings -->
  <appSettings>
    <!-- React app runs on default port in App Service -->
    <add key="WEBSITE_NODE_DEFAULT_VERSION" value="18.17.1" />
  </appSettings>
</configuration>
