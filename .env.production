# ============================================================================
# ENERGY DASHBOARD - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# This is a template for production environment variables
# Do NOT commit actual secrets - use secure secrets management (e.g., AWS Secrets Manager)

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_ENV=production
APP_NAME=Energy Dashboard
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=WARNING

# ============================================================================
# FASTAPI SERVER
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False
FRONTEND_URL=https://yourdomain.com

# ============================================================================
# DATABASE
# ============================================================================
# DATABASE_URL=postgresql://prod_user:prod_password@prod-db-host:5432/energy_db

# ============================================================================
# SHAREPOINT INTEGRATION
# ============================================================================
SHAREPOINT_TENANT_ID=your_production_tenant_id
SHAREPOINT_CLIENT_ID=your_production_client_id
SHAREPOINT_CLIENT_SECRET=your_production_client_secret
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/ProdSite
SHAREPOINT_LIST_ID=your_production_list_id

# ============================================================================
# GOOGLE SHEETS INTEGRATION
# ============================================================================
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google_credentials.json
GOOGLE_SHEET_ID=your_production_sheet_id
GOOGLE_SHEET_RANGE=Sheet1!A1:Z1000

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=production_email@company.com
SMTP_PASSWORD=production_email_password
SMTP_FROM_EMAIL=noreply@company.com
SMTP_USE_TLS=True

# ============================================================================
# SCHEDULING
# ============================================================================
SCHEDULE_INGESTION_DAILY=09:00
SCHEDULE_EMAIL_DAILY=18:00
TIMEZONE=Asia/Kolkata

# ============================================================================
# DATA INGESTION
# ============================================================================
DATA_INGESTION_TIMEOUT=3600
DATA_CACHE_EXPIRY=7200
DATA_RETENTION_DAYS=365

# ============================================================================
# API KEYS
# ============================================================================
GROQ_API_KEY=your_production_groq_api_key

# ============================================================================
# CORS SETTINGS
# ============================================================================
ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
LOG_FILE_PATH=/app/logs/app.log

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
